{
  "expo": {
    "name": "Bread&Light",
    "slug": "goden",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "goden",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B3A6B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.goden.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Bread&Light uses the microphone so you can practice reading Bible verses aloud and get gentle pronunciation feedback."
      }
    },
    "android": {
      "package": "com.goden.app",
      "permissions": ["RECORD_AUDIO"]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}